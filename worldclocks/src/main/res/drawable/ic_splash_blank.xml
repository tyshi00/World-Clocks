<?xml version="1.0" encoding="utf-8"?>
<!--
    Solid black square, matching the splash background exactly, rather than a
    literally empty drawable. An empty vector (no <path> elements at all) trips
    a fallback in the platform SplashScreen implementation - when it finds no
    valid icon content, it falls back toward the app's launcher icon, which
    isn't declared via android:icon in this SDK's generated manifest either,
    so it cascades down to a generic system default. A real but all-black
    drawable passes that validity check while staying visually invisible
    against the equally-black splash background, regardless of any icon-shape
    masking the OS applies around it. (Same reasoning as Passatempo's
    ic_splash_blank.xml, which this mirrors.)
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path
        android:pathData="M0,0h108v108h-108z"
        android:fillColor="#000000" />
</vector>
